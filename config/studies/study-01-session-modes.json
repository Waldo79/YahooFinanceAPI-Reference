{
  "study_id": "study-01-session-mode-requirements",
  "study_version": "0.1.0",
  "study_title": "Seven-endpoint session-mode requirements",
  "study_variable": "session_mode",
  "subject": "AAPL",
  "mode_order": [
    "cookie-crumb",
    "cookie-only",
    "no-session"
  ],
  "modes": [
    {
      "session_mode": "cookie-crumb",
      "description": "Prepare an anonymous Yahoo cookie-and-crumb session and add the crumb query parameter.",
      "prepare_cookie": true,
      "retrieve_crumb": true,
      "send_crumb": true
    },
    {
      "session_mode": "cookie-only",
      "description": "Perform the same anonymous cookie-and-crumb preparation, but deliberately omit the crumb query parameter.",
      "prepare_cookie": true,
      "retrieve_crumb": true,
      "send_crumb": false
    },
    {
      "session_mode": "no-session",
      "description": "Use a fresh opener without a prepared Yahoo cookie jar or crumb.",
      "prepare_cookie": false,
      "retrieve_crumb": false,
      "send_crumb": false
    }
  ],
  "requests": [
    {
      "request_id": "quote-aapl-minimal",
      "endpoint_id": "quote",
      "method": "GET",
      "base_url": "https://query1.finance.yahoo.com/v7/finance/quote",
      "params": {
        "symbols": "{subject}",
        "formatted": "false",
        "lang": "en-US",
        "region": "US"
      },
      "expected_top_level": "quoteResponse"
    },
    {
      "request_id": "chart-aapl-5d-1d",
      "endpoint_id": "chart",
      "method": "GET",
      "base_url": "https://query2.finance.yahoo.com/v8/finance/chart/{subject}",
      "params": {
        "range": "5d",
        "interval": "1d",
        "includePrePost": "false",
        "events": "div,splits,capitalGains"
      },
      "expected_top_level": "chart"
    },
    {
      "request_id": "quote-summary-aapl-price-summary-detail",
      "endpoint_id": "quote-summary",
      "method": "GET",
      "base_url": "https://query2.finance.yahoo.com/v10/finance/quoteSummary/{subject}",
      "params": {
        "modules": "price,summaryDetail",
        "formatted": "false",
        "corsDomain": "finance.yahoo.com",
        "lang": "en-US",
        "region": "US",
        "symbol": "{subject}"
      },
      "expected_top_level": "quoteSummary"
    },
    {
      "request_id": "search-aapl-exact",
      "endpoint_id": "search",
      "method": "GET",
      "base_url": "https://query2.finance.yahoo.com/v1/finance/search",
      "params": {
        "q": "{subject}",
        "quotesCount": "5",
        "enableFuzzyQuery": "false",
        "newsCount": "0",
        "quotesQueryId": "tss_match_phrase_query",
        "newsQueryId": "news_cie_vespa",
        "listsCount": "0",
        "enableCb": "true",
        "enableNavLinks": "false",
        "enableResearchReports": "false",
        "enableCulturalAssets": "false",
        "recommendedCount": "0"
      },
      "expected_top_level": "quotes"
    },
    {
      "request_id": "screener-day-gainers-five",
      "endpoint_id": "screener",
      "method": "GET",
      "base_url": "https://query1.finance.yahoo.com/v1/finance/screener/predefined/saved",
      "params": {
        "scrIds": "day_gainers",
        "count": "5",
        "offset": "0",
        "corsDomain": "finance.yahoo.com",
        "formatted": "false",
        "lang": "en-US",
        "region": "US"
      },
      "expected_top_level": "finance"
    },
    {
      "request_id": "fundamentals-aapl-quarterly-market-cap",
      "endpoint_id": "fundamentals-timeseries",
      "method": "GET",
      "base_url": "https://query2.finance.yahoo.com/ws/fundamentals-timeseries/v1/finance/timeseries/{subject}",
      "params": {
        "symbol": "{subject}",
        "type": "quarterlyMarketCap"
      },
      "dynamic_period_days": 730,
      "expected_top_level": "timeseries"
    },
    {
      "request_id": "options-aapl-nearest-expiration",
      "endpoint_id": "options",
      "method": "GET",
      "base_url": "https://query2.finance.yahoo.com/v7/finance/options/{subject}",
      "params": {},
      "expected_top_level": "optionChain"
    }
  ]
}
